# Template for apps/agent-telemetry/manifests/secret.enc.yaml.
# Workflow:
#   1. cp apps/agent-telemetry/secret.enc.yaml.tmpl apps/agent-telemetry/manifests/secret.enc.yaml
#   2. Edit `token:` below with the value generated by `openssl rand -hex 32`.
#   3. sops --encrypt --in-place apps/agent-telemetry/manifests/secret.enc.yaml
#   4. git add / commit / push
#
# This template lives outside `manifests/` so ArgoCD never tries to apply the plaintext.
apiVersion: isindir.github.com/v1alpha3
kind: SopsSecret
metadata:
  name: agent-telemetry-server-token
  namespace: agent-telemetry
spec:
  secretTemplates:
    - name: agent-telemetry-server-token
      stringData:
        token: REPLACE_WITH_OPENSSL_RAND_HEX_32
